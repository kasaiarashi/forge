<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="FgH1Size">28</x:Double>
    <x:Double x:Key="FgH2Size">20</x:Double>
    <x:Double x:Key="FgBodySize">14</x:Double>
    <x:Double x:Key="FgCaptionSize">12</x:Double>

    <Thickness x:Key="FgCardPadding">20</Thickness>
    <Thickness x:Key="FgPagePadding">32,24,32,24</Thickness>
    <x:Double x:Key="FgCornerRadius">8</x:Double>
    <Thickness x:Key="FgListItemPadding">8,10,8,10</Thickness>

    <Style x:Key="FgH1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FgH1Size}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="FgH2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FgH2Size}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="FgCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FgCaptionSize}" />
        <Setter Property="Opacity" Value="0.7" />
    </Style>

    <Style x:Key="FgCard" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource FgCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource FgCardPadding}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Loosen ListView row density so asset paths + metadata breathe. -->
    <Style x:Key="FgListItem" TargetType="ListViewItem">
        <Setter Property="Padding" Value="{StaticResource FgListItemPadding}" />
        <Setter Property="MinHeight" Value="40" />
    </Style>
</ResourceDictionary>
