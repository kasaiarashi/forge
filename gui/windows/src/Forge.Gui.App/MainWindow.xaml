<Window
    x:Class="Forge.Gui.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (Mica extends here).
             Right column reserves caption-button space via RightPaddingColumn
             so our Refresh/Settings/Account buttons don't overlap min/max/close. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaddingColumn"  Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="RightPaddingColumn" Width="148" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8A5;" FontSize="16" />
                <TextBlock Text="Forge" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <muxc:DropDownButton Grid.Column="2" x:Name="RepoSwitcher" HorizontalAlignment="Center"
                                 VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8B7;" FontSize="14" Opacity="0.8" />
                    <TextBlock x:Name="RepoSwitcherLabel" Text="DemoArena / dev" FontWeight="SemiBold" />
                </StackPanel>
                <muxc:DropDownButton.Flyout>
                    <MenuFlyout x:Name="RepoMenu" Placement="Bottom" Opening="OnRepoMenuOpening">
                        <MenuFlyoutSeparator x:Name="RecentSeparator" Visibility="Collapsed" />
                        <MenuFlyoutItem Text="Open folder…" Click="OnOpenFolderClicked">
                            <MenuFlyoutItem.Icon><SymbolIcon Symbol="OpenFile" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Clone…" Click="OnCloneClicked">
                            <MenuFlyoutItem.Icon><SymbolIcon Symbol="Download" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </muxc:DropDownButton.Flyout>
            </muxc:DropDownButton>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                        Margin="0,0,12,0">
                <Button Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Refresh"
                        Click="OnRefreshClicked">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
                <Button Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Settings"
                        Click="OnSettingsClicked">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
                <Button Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Account">
                    <FontIcon Glyph="&#xE77B;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Nav rail + content -->
        <muxc:NavigationView
            Grid.Row="1"
            x:Name="Nav"
            PaneDisplayMode="LeftCompact"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="220"
            SelectionChanged="OnNavSelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Tag="home" Content="Home" IsSelected="True">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItemSeparator />
                <muxc:NavigationViewItem Tag="changes" Content="Changes">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE8A5;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Tag="history" Content="History">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE81C;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Tag="locks" Content="Locks">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE72E;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Tag="branches" Content="Branches">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE8AB;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItemSeparator x:Name="AdvancedSep" Visibility="Collapsed" />
                <muxc:NavigationViewItem x:Name="StashItem" Tag="stash" Content="Stash" Visibility="Collapsed">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE74E;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="TagsItem" Tag="tags" Content="Tags" Visibility="Collapsed">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE8EC;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="StatsItem" Tag="stats" Content="Stats" Visibility="Collapsed">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE9D9;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
