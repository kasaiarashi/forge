<ContentDialog
    x:Class="Forge.Gui.App.Dialogs.CloneDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Clone repository"
    PrimaryButtonText="Clone"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryClicked">

    <StackPanel Width="420" Spacing="10">
        <TextBox Header="Server URL"
                 PlaceholderText="https://forge.example.com:50051/alice/game"
                 Text="{x:Bind Vm.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <TextBox Header="Destination folder"
                 PlaceholderText="C:\Projects\my-repo"
                 Text="{x:Bind Vm.Destination, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <PasswordBox Header="Personal Access Token (optional)"
                     Password="{x:Bind Vm.Token, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Spacing="4" Visibility="{x:Bind Vm.IsCloning, Mode=OneWay}">
            <TextBlock Text="{x:Bind Vm.ProgressStage, Mode=OneWay}" FontSize="12" Opacity="0.7" />
            <ProgressBar Value="{x:Bind Vm.ProgressFraction, Mode=OneWay}" Minimum="0" Maximum="1" />
        </StackPanel>

        <TextBlock Text="{x:Bind Vm.ErrorMessage, Mode=OneWay}"
                   Foreground="{ThemeResource FgDeletedBrush}"
                   TextWrapping="Wrap"
                   Visibility="{x:Bind Vm.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToCollapsed}}" />
    </StackPanel>
</ContentDialog>
