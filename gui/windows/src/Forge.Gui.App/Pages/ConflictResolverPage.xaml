<Page
    x:Class="Forge.Gui.App.Pages.ConflictResolverPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Forge.Gui.Core.ViewModels">

    <Grid ColumnSpacing="16" RowSpacing="12" Padding="{StaticResource FgPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="Resolve conflicts" Style="{StaticResource FgH1}" />
            <TextBlock Style="{StaticResource FgCaption}" VerticalAlignment="Center">
                <Run Text="{x:Bind Vm.ResolvedCount, Mode=OneWay}" />
                <Run Text=" of " />
                <Run Text="{x:Bind Vm.TotalCount, Mode=OneWay}" />
                <Run Text=" files resolved" />
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource FgCard}">
            <ListView ItemsSource="{x:Bind Vm.Files}"
                      SelectedItem="{x:Bind Vm.Selected, Mode=TwoWay}"
                      Background="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FileConflictViewModel">
                        <Grid Padding="4,6,4,6" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE783;" FontSize="12" Foreground="{ThemeResource FgConflictBrush}" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource FgCard}">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Opacity="0.6"
                            Visibility="{x:Bind Vm.Selected, Mode=OneWay, Converter={StaticResource NullToCollapsed}, ConverterParameter=invert}">
                    <FontIcon Glyph="&#xE8E8;" FontSize="32" />
                    <TextBlock Text="Select a conflict to resolve" />
                </StackPanel>

                <ScrollViewer Visibility="{x:Bind Vm.Selected, Mode=OneWay, Converter={StaticResource NullToCollapsed}}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{x:Bind Vm.Selected.Path, Mode=OneWay, FallbackValue=''}" FontWeight="SemiBold" />

                        <ItemsRepeater ItemsSource="{x:Bind Vm.Selected.Properties, Mode=OneWay, FallbackValue=''}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:PropertyConflictViewModel">
                                    <StackPanel Padding="0,8,0,8" Spacing="6">
                                        <TextBlock Text="{x:Bind PropertyPath}" FontFamily="Cascadia Mono" FontWeight="SemiBold" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Padding="8" CornerRadius="4" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Base" Style="{StaticResource FgCaption}" />
                                                    <TextBlock Text="{x:Bind BaseValue, FallbackValue=''}" FontFamily="Cascadia Mono" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" Padding="8" CornerRadius="4" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Ours" Style="{StaticResource FgCaption}" />
                                                    <TextBlock Text="{x:Bind OurValue, FallbackValue=''}" FontFamily="Cascadia Mono" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="2" Padding="8" CornerRadius="4" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Theirs" Style="{StaticResource FgCaption}" />
                                                    <TextBlock Text="{x:Bind TheirValue, FallbackValue=''}" FontFamily="Cascadia Mono" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <RadioButton Content="Take ours"   IsChecked="{x:Bind ChooseOurs,   Mode=TwoWay}" GroupName="{x:Bind PropertyPath}" />
                                            <RadioButton Content="Take theirs" IsChecked="{x:Bind ChooseTheirs, Mode=TwoWay}" GroupName="{x:Bind PropertyPath}" />
                                            <RadioButton Content="Custom"      IsChecked="{x:Bind ChooseCustom, Mode=TwoWay}" GroupName="{x:Bind PropertyPath}" />
                                        </StackPanel>
                                        <TextBox Text="{x:Bind CustomValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="Custom value"
                                                 IsEnabled="{x:Bind ChooseCustom, Mode=OneWay}"
                                                 FontFamily="Cascadia Mono" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Mark resolved" Command="{x:Bind Vm.MarkResolvedCommand}" />
                            <Button Content="Commit merge" Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
