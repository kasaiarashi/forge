<Page
    x:Class="Forge.Gui.App.Pages.BranchesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Forge.Gui.Core.Models">

    <Grid RowSpacing="12" ColumnSpacing="16" Padding="{StaticResource FgPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.ColumnSpan="2" Text="Branches" Style="{StaticResource FgH1}" />

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource FgCard}">
            <StackPanel Spacing="4">
                <TextBlock Text="Local" Style="{StaticResource FgH2}" />
                <ListView ItemsSource="{x:Bind Vm.Local, Mode=OneWay}" Background="Transparent"
                          ItemContainerStyle="{StaticResource FgListItem}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Branch">
                            <Grid Padding="4,6,4,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE73E;" FontSize="12"
                                          Visibility="{x:Bind IsCurrent}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind TipHash}" FontFamily="Cascadia Mono" Opacity="0.6" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource FgCard}">
            <StackPanel Spacing="4">
                <TextBlock Text="Remote" Style="{StaticResource FgH2}" />
                <ListView ItemsSource="{x:Bind Vm.Remote, Mode=OneWay}" Background="Transparent"
                          ItemContainerStyle="{StaticResource FgListItem}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Branch">
                            <Grid Padding="4,6,4,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Name}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind TipHash}" FontFamily="Cascadia Mono" Opacity="0.6" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>
