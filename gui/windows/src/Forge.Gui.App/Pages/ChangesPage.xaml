<Page
    x:Class="Forge.Gui.App.Pages.ChangesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Forge.Gui.Core.Models"
    xmlns:conv="using:Forge.Gui.App.Converters"
    xmlns:controls="using:Forge.Gui.App.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <conv:ChangeKindToBrushConverter x:Key="KindBrush" />
        <conv:ChangeKindToGlyphConverter x:Key="KindGlyph" />
    </Page.Resources>

    <Grid ColumnSpacing="16" Padding="{StaticResource FgPagePadding}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: change list + commit box -->
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="Changes" Style="{StaticResource FgH1}" />
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="10" Padding="8,2,8,2" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Vm.Total, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                </Border>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource FgCard}">
                <ListView x:Name="ChangeList" SelectionMode="Extended" ItemsSource="{x:Bind Vm.Unstaged, Mode=OneWay}"
                          Background="Transparent" SelectionChanged="OnChangeSelectionChanged"
                          ItemContainerStyle="{StaticResource FgListItem}">
                    <ListView.Header>
                        <TextBlock Text="Unstaged" Style="{StaticResource FgH2}" Margin="4,0,0,4" />
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:FileChange">
                            <Grid Padding="4,6,4,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Kind, Converter={StaticResource KindGlyph}}"
                                           Foreground="{x:Bind Kind, Converter={StaticResource KindBrush}}"
                                           FontFamily="Cascadia Mono" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                                <FontIcon Grid.Column="2" Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource FgLockedBrush}"
                                          Visibility="{x:Bind IsLocked}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource FgCard}">
                <StackPanel Spacing="8">
                    <TextBox x:Name="MessageBox" PlaceholderText="Commit message"
                             Text="{x:Bind Vm.CommitMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" />
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Commit" Command="{x:Bind Vm.CommitCommand}" />
                        <Button Content="Commit &amp; Push" Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind Vm.CommitAndPushCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Right: diff preview -->
        <Border Grid.Column="1" Style="{StaticResource FgCard}">
            <controls:DiffView x:Name="Diff" />
        </Border>
    </Grid>
</Page>
