<Page
    x:Class="Forge.Gui.App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Forge.Gui.Core.ViewModels">

    <ScrollViewer>
        <Grid Padding="48,40,48,40" RowSpacing="32" MaxWidth="980" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Hero -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind Vm.Greeting, Mode=OneWay}" FontSize="15" Opacity="0.7" />
                <TextBlock Text="Forge" FontSize="48" FontWeight="SemiBold" />
                <TextBlock Text="{x:Bind Vm.Subtitle, Mode=OneWay}" FontSize="16" Opacity="0.75"
                           TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Primary actions -->
            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="20" Style="{StaticResource AccentButtonStyle}"
                        Click="OnOpenFolderClicked">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE838;" FontSize="26" HorizontalAlignment="Left" />
                        <TextBlock Text="Open workspace" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Point Forge at a folder with a .forge directory."
                                   Opacity="0.85" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="20" Click="OnCloneClicked">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="26" HorizontalAlignment="Left" />
                        <TextBlock Text="Clone from server" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Download an existing Forge repository."
                                   Opacity="0.75" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="20" Click="OnSignInClicked">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE77B;" FontSize="26" HorizontalAlignment="Left" />
                        <TextBlock Text="Sign in" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Add a server + personal access token."
                                   Opacity="0.75" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Recents -->
            <StackPanel Grid.Row="2" Spacing="12"
                        Visibility="{x:Bind Vm.HasRecents, Mode=OneWay}">
                <TextBlock Text="Recent" Style="{StaticResource FgH2}" />
                <ItemsRepeater ItemsSource="{x:Bind Vm.Recents, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="300" MinItemHeight="96"
                                           MinColumnSpacing="12" MinRowSpacing="12" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:HomeRecentRepo">
                            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    VerticalContentAlignment="Top"
                                    Padding="16,14,16,14" Tag="{x:Bind Path}"
                                    Click="OnRecentClicked">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Width="4" Height="20" CornerRadius="2"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}" />
                                        <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="15" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Path}" FontFamily="Cascadia Mono"
                                               FontSize="11" Opacity="0.7"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <!-- Empty state -->
            <StackPanel Grid.Row="2" Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,40,0,0" Opacity="0.85"
                        Visibility="{x:Bind Vm.HasRecents, Mode=OneWay, Converter={StaticResource BoolNot}}">
                <FontIcon Glyph="&#xE8B7;" FontSize="40" HorizontalAlignment="Center" Opacity="0.5" />
                <TextBlock Text="No repositories yet" HorizontalAlignment="Center" FontSize="14" Opacity="0.7" />
                <TextBlock Text="Use Open workspace or Clone to get started." HorizontalAlignment="Center" FontSize="12" Opacity="0.55" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
