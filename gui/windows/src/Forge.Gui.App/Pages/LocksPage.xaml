<Page
    x:Class="Forge.Gui.App.Pages.LocksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Forge.Gui.Core.Models">

    <Grid RowSpacing="12" Padding="{StaticResource FgPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Locks" Style="{StaticResource FgH1}" />

        <Border Grid.Row="1" Style="{StaticResource FgCard}">
            <ListView ItemsSource="{x:Bind Vm.Locks, Mode=OneWay}" Background="Transparent"
                      ItemContainerStyle="{StaticResource FgListItem}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LockInfo">
                        <Grid Padding="4,10,4,10" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="{ThemeResource FgLockedBrush}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind Path}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Reason}" Style="{StaticResource FgCaption}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBlock Text="{x:Bind Owner}" />
                                <TextBlock Text="{x:Bind AcquiredAt}" Style="{StaticResource FgCaption}" />
                            </StackPanel>
                            <Button Grid.Column="3" Content="Release" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
