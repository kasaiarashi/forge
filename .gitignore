target/
dist/
forge-web.toml
!installers/config/forge-web.toml
!docker/forge-web.toml

# Auto-generated TLS keys/certs from [server.tls].auto_generate or
# [web.tls].auto_generate. Never commit private keys.
forge-web-certs/
forge-data/
*.pem
*.key
!proto/*.proto

# Local MSVC env-setup script — operator-specific paths.
_build_temp.bat
.build-tmp/

# Forge GUI (.NET / WinUI) build output
gui/**/bin/
gui/**/obj/
gui/**/AppPackages/
gui/**/BundleArtifacts/
gui/**/GeneratedArtifacts/
gui/**/*.user
gui/**/.vs/

# Claude Code runtime files (per-session, not for git).
.claude/scheduled_tasks.lock

# Local dev copy of forge_ffi.dll inside the UE plugin tree. The
# release flow installs the DLL via the Windows client installer (see
# installers/windows/forge-client.iss); the plugin discovers it at
# load time via env + registry. Don't ship a stale binary in the repo.
plugin/ForgeSourceControl/Plugins/ForgeSourceControl/Binaries/Win64/forge_ffi.dll